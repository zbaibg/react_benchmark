# =============================================================================
# react_benchmark .gitignore
#
# KEEP on remote:
#   - tools/, structures/, params/, software.yaml, README, scripts, templates
#   - run_configs.yaml and other YAML settings
#   - optimized geometries: **/min.xyz (and campaign xyz/ inputs)
#   - tabulated results: **/*.csv (and small summary outs)
#   - amber_prep libraries / force-field files
#
# DROP (regenerable or huge scratch):
#   - QM wavefunctions, integrals, DIIS/tmp, Molpro/MRCC scratch
#   - gen_struc_* numbered worker trees (keep ana_* summaries)
#   - optimization trajectories (path*.xyz)
#   - waste copies, caches, slurm logs
# =============================================================================

# ----- Python / editor / OS -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.mplconfig/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.cursor/
.vscode/
.idea/

# ----- Nested / discarded copies -----
**/waste1/
**/waste2/
**/waste/

# ----- Trajectory / cpptraj intermediates (final xyz live under xyz/) -----
**/cpptraj_logs/
**/*autoimaged*

# ----- Structure-generation worker trees (keep ana_* under gen_struc*) -----
**/gen_struc*/[0-9]/
**/gen_struc*/[0-9][0-9]/
**/gen_struc*/[0-9][0-9][0-9]/
**/gen_struc*/**/work_dir/
**/gen_struc*/**/save_dir/

# ----- Job trees -----
# SP_init / SP_opt: ignore entirely (regenerable; energies live in campaign csv)
**/SP_init/
**/SP_opt/

# qm_minimize / minimize: keep only optimized geometries
**/qm_minimize/**
!**/qm_minimize/**/
!**/qm_minimize/**/min.xyz

**/minimize/**
!**/minimize/**/
!**/minimize/**/min.xyz

# Optimization trajectories (final structure is min.xyz)
**/path.xyz
**/path_active.xyz
**/path_force.xyz
**/path.pdb
**/xtbopt.log
**/gradient

# ----- QM binary / integral / scratch dumps -----
*.gbw
*.densities
*.densitiesinfo
*.loc
*.ges
*.bas0
*.bas1
*.bas2
*.bas3
*.bas4
*.bas5
*.pc
*.qro
*.uno
*.unso
*.prop
*.hess
*.cipci
*.dmat*
*.tmp
*.tmp.*
*.diisao.tmp*
*.xml-sidecar
*.chk
*.chk.*

orc_job.dat
**/old.orc_job.dat
orc_job.bibtex
molpro.log
mrcc.log

# Molpro / MRCC scratch-like names (often no extension)
FOCK
FOCK_*
SROOT
SROOT_*
OEINT
PRINT
MOCOEF
MOCOEF_*
SCHOL
VARS
VARS_*
VARS.old
DFINV
DFINVLOC
DFINT*
F12INT*
S12MAT*
SCFDENSITIES
TEDAT
SYMTRA
OCCUP
KEYWD
EXIT
DOMAIN_AO
DAO
iface
fort.*

# Bare numeric MRCC unit files (e.g. "55")
**/[0-9]
**/[0-9][0-9]
**/[0-9][0-9][0-9]
**/[0-9][0-9][0-9][0-9]

# ----- Verbose / regenerable QM text dumps (energies live in csv / notes) -----
**/run.xml
*.out_[0-9]*
out_[0-9]*
**/out_[0-9]*
**/detailed.out
**/component_runs/
**/GENBAS
**/mrcc/**/out
**/mrcc_new/**/out
*.bin
*.engrad

# ----- Slurm / job noise -----
slurm-*.out
slurm-*.err
sbatch.log
*sbatch.log
prepare_sbatch.log
*.log
core.*
*.err

# ----- Optional local overrides -----
software.local.yaml
.env
.env.*

# ----- Backups last (override job-tree allowlists) -----
**/old/
**/bk/
